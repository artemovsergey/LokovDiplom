{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "../AppData/Roaming/Code/User/workspaceStorage/65e4cb518235b284884283402ced1fa8/ms-dotnettools.csdevkit/LokovDiplom.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "../AppData/Roaming/Code/User/workspaceStorage/65e4cb518235b284884283402ced1fa8/ms-dotnettools.csdevkit/LokovDiplom.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "../AppData/Roaming/Code/User/workspaceStorage/65e4cb518235b284884283402ced1fa8/ms-dotnettools.csdevkit/LokovDiplom.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "type": "docker-build",
            "label": "docker-build: debug",
            "dependsOn": ["build"],
            "dockerBuild": {
                "tag": "lokovdiplom:dev",
                "target": "base",
                "dockerfile": "${workspaceFolder}/LokovApp/Dockerfile",
                "context": "${workspaceFolder}",
                "pull": true
            },
            "netCore": {
                "appProject": "${workspaceFolder}/LokovApp/LokovApp.csproj"
            }
        },
        {
            "type": "docker-build",
            "label": "docker-build: release",
            "dependsOn": ["build"],
            "dockerBuild": {
                "tag": "lokovdiplom:latest",
                "dockerfile": "${workspaceFolder}/LokovApp/Dockerfile",
                "context": "${workspaceFolder}",
                "platform": {
                    "os": "linux",
                    "architecture": "amd64"
                },
                "pull": true
            },
            "netCore": {
                "appProject": "${workspaceFolder}/LokovApp/LokovApp.csproj"
            }
        },
        {
            "type": "docker-run",
            "label": "docker-run: debug",
            "dependsOn": ["docker-build"],
            "dockerRun": {
                "env": {
                    "DEBUG": "*",
                    "NODE_ENV": "development"
                }
            },
            "node": {
                "package": "${workspaceFolder}/lokovapp.react/package.json",
                "enableDebugging": true
            }
        },
        {
            "type": "docker-run",
            "label": "docker-run: release",
            "dependsOn": ["docker-build"],
            "platform": "node",
            "node": {
                "package": "${workspaceFolder}/lokovapp.react/package.json"
            }
        },
        {
            "type": "docker-build",
            "label": "docker-build",
            "platform": "node",
            "dockerBuild": {
                "dockerfile": "${workspaceFolder}/lokovapp.react/Dockerfile",
                "context": "${workspaceFolder}/lokovapp.react",
                "pull": true
            },
            "node": {
                "package": "${workspaceFolder}/lokovapp.react/package.json"
            }
        }
    ]
}
